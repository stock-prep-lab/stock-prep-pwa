{
  "name": "@stock-prep/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "prebuild": "pnpm --filter @stock-prep/shared build && pnpm --filter @stock-prep/domain build",
    "pretest": "pnpm --filter @stock-prep/shared build && pnpm --filter @stock-prep/domain build",
    "preview": "vite preview",
    "test": "vitest run",
    "pretypecheck": "pnpm --filter @stock-prep/shared build && pnpm --filter @stock-prep/domain build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@stock-prep/domain": "workspace:*",
    "@stock-prep/shared": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5",
    "vitest": "^4.1.4"
  }
}
